---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrambleText from '../../components/ScrambleText.astro';
import BrutalButton from '../../components/BrutalButton.astro';
import FramedImage from '../../components/FramedImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const members = await getCollection('members');
  return members.map((member) => ({
    params: { slug: member.id },
    props: { member },
  }));
}

const { member } = Astro.props;
const { codename, discipline, bio, portrait, manifesto, signatureData } = member.data;
---

<BaseLayout title={codename}>
  <!-- Split layout: content left, portrait right -->
  <section class="border-b-2 border-white grid grid-cols-1 lg:grid-cols-2 min-h-[80vh]">
    <!-- Left: content -->
    <div class="flex flex-col justify-center px-6 md:px-12 py-16 border-b-2 lg:border-b-0 lg:border-r-2 border-white relative overflow-hidden">
      <span class="chaotic-text text-[20vw] top-[5%] left-[-5%] rotate-[-3deg]">{codename}</span>

      <div data-reveal="up">
        <span class="font-mono text-[10px] text-white/40 block mb-4 tracking-widest">[{discipline}]</span>
        <ScrambleText
          text={codename}
          tag="h1"
          class="font-display text-6xl md:text-8xl tracking-tight"
        />
        <p class="font-mono text-sm text-white/60 mt-4 max-w-md">{bio}</p>
      </div>

      <!-- Manifesto -->
      <div class="mt-10" data-reveal="up" data-reveal-delay="200">
        <span class="font-mono text-[10px] text-white/30 tracking-widest block mb-3">[MANIFESTO]</span>
        <p class="font-mono text-sm md:text-base leading-relaxed text-white/70 max-w-lg">
          {manifesto}
        </p>
      </div>

      <!-- REC badge -->
      <div class="absolute top-4 left-4 flex items-center gap-1.5 bg-black/70 px-3 py-1">
        <span class="inline-block w-2 h-2 bg-rec"></span>
        <span class="font-mono text-xs text-rec">REC</span>
      </div>
    </div>

    <!-- Right: portrait -->
    <div class="relative member-portrait h-[50vh] lg:h-auto">
      <img src={portrait} alt={codename} class="w-full h-full object-cover object-top member-portrait-img" />
      <div class="member-portrait-vignette"></div>
      <div class="member-portrait-noise"></div>
      <div class="member-portrait-scanlines"></div>
      <div class="glitch-scanlines"></div>
      <div class="glitch-tear"></div>
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-6 z-10 lg:hidden">
        <span class="font-display text-outline text-4xl">{codename}</span>
      </div>
    </div>
  </section>

  <!-- Liquid BG divider -->
  <section class="border-b-2 border-white">
    <div class="liquid-bg h-[20vh] md:h-[30vh]" data-hover>
      <img src="/images/bg/black-white-dristessed-background.png" alt="" class="w-full h-full object-cover" loading="lazy" />
    </div>
  </section>

  <!-- Work archive strip -->
  <section class="relative border-b-2 border-white px-4 md:px-8 py-12 md:py-16 overflow-hidden">
    <div class="floating-img hidden md:block" style="top: 8%; right: 4%; transform: rotate(-5deg); width: 180px;" data-float-speed="1.3" data-base-rot="-5" data-parallax-dir="1">
      <img src="/images/random/retro-shot.jpg" alt="" class="floating-img-inner" loading="lazy" />
      <div class="floating-img-vignette"></div>
      <div class="floating-img-noise"></div>
      <div class="floating-img-scanlines"></div>
    </div>
    <div class="floating-img hidden lg:block" style="bottom: 10%; left: 60%; transform: rotate(7deg); width: 120px;" data-float-speed="0.6" data-base-rot="7" data-parallax-dir="-1">
      <img src="/images/random/lookback-shot.jpg" alt="" class="floating-img-inner" loading="lazy" />
      <div class="floating-img-vignette"></div>
      <div class="floating-img-noise"></div>
      <div class="floating-img-scanlines"></div>
    </div>

    <div class="flex items-baseline justify-between mb-8" data-reveal="up">
      <span class="font-mono text-[10px] text-white/30 tracking-widest">[ARCHIVE // SELECTED WORK]</span>
      <span class="font-mono text-[10px] text-white/20">{codename}_ARCHIVE</span>
    </div>
    <div class="flex gap-4 overflow-x-auto pb-4" data-reveal="left">
      {(signatureData?.images || ['/images/random/retro-shot.jpg', '/images/random/lookback-shot.jpg', '/images/random/random-img-two-person.jpg']).map((src: string, i: number) => (
        <FramedImage
          src={src}
          label={`${codename}_${String(i + 1).padStart(3, '0')}`}
          class="w-48 md:w-64 aspect-[3/4] flex-shrink-0"
        />
      ))}
    </div>
  </section>

  <!-- Back -->
  <section class="px-4 md:px-8 py-8 flex items-center justify-between">
    <BrutalButton href="/members" label="BACK TO ROSTER" />
    <span class="font-mono text-[10px] text-white/20 hidden md:block">[END OF FILE]</span>
  </section>
</BaseLayout>
