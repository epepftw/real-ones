---
interface Props {
  href?: string;
  label: string;
  class?: string;
}
const { href, label, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class:list={[
    'inline-block font-mono text-xs md:text-sm border border-white px-6 py-2.5 text-white uppercase tracking-wider hover:bg-white hover:text-black transition-none cursor-pointer',
    className,
  ]}
>
  [{label}]
</Tag>
