---
interface Props {
  data: { bars: number[] };
}
const { data } = Astro.props;
const bars = data?.bars || [0.5, 0.7, 0.3, 0.9, 0.4, 0.8, 0.2, 0.6, 0.5, 0.7, 0.3, 0.9, 0.4, 0.8, 0.2, 0.6];
---

<div class="flex items-end gap-[2px] h-12 w-full">
  {bars.map((h: number, i: number) => (
    <div
      class="flex-1 bg-white/70 waveform-bar"
      style={`height: ${h * 100}%; animation-delay: ${i * 0.1}s;`}
    ></div>
  ))}
</div>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 0.3; }
  }
  .waveform-bar {
    animation: pulse 1.5s ease-in-out infinite;
  }
</style>
