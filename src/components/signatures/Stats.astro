---
interface Props {
  data: { stats: { label: string; value: string }[] };
}
const { data } = Astro.props;
const stats = data?.stats || [];
---

<div class="grid grid-cols-2 gap-x-4 gap-y-1">
  {stats.map((s: { label: string; value: string }) => (
    <div class="flex flex-col">
      <span class="font-mono text-[8px] text-white/40">{s.label}</span>
      <span class="font-mono text-sm text-white">{s.value}</span>
    </div>
  ))}
</div>
