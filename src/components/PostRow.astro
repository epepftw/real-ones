---
interface Props {
  id: string;
  title: string;
  date: string;
  category: string;
  index?: number;
}
const { id, title, date, category, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<a href={`/blog/${id}`} class="block border-b-2 border-white hover:bg-white hover:text-black transition-none group" data-hover>
  <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 px-4 md:px-8 py-5 md:py-6">
    <span class="font-display text-outline text-2xl md:text-3xl opacity-40 shrink-0 w-12">{num}</span>
    <span class="font-mono text-xs text-white/40 group-hover:text-black/40 shrink-0">[{date}]</span>
    <h3 class="font-display text-xl md:text-2xl lg:text-3xl tracking-tight flex-1">{title}</h3>
    <span class="font-mono text-[10px] border-2 border-white/30 group-hover:border-black/30 px-3 py-1 shrink-0 self-start md:self-auto">[{category}]</span>
  </div>
</a>
